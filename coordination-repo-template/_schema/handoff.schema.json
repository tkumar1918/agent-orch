{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/handoff.schema.json",
  "title": "Handoff Manifest",
  "description": "Frontmatter schema for a cross-repo agent handoff message.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "handoff_id",
    "from",
    "to",
    "created_by",
    "status",
    "contract_status",
    "contract_version",
    "breaking",
    "severity",
    "intent",
    "required_actions"
  ],
  "properties": {
    "handoff_id": {
      "type": "string",
      "description": "Unique id: YYYY-MM-DD-<side>-NNN-<rand> (rand = 2-8 hex chars)",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}-(frontend|backend|fe|be)-[0-9]{3}-[0-9a-f]{2,8}$"
    },
    "from": { "type": "string", "enum": ["frontend", "backend"] },
    "to": { "type": "string", "enum": ["frontend", "backend"] },
    "created_by": {
      "type": "string",
      "description": "Human who approved this handoff (agent drafts, human approves)."
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "acknowledged", "in-progress", "completed", "blocked", "rejected"]
    },
    "contract_status": {
      "type": "string",
      "enum": ["proposed", "released"],
      "description": "proposed = contract lives on a branch; released = merged to main."
    },
    "contract_branch": {
      "type": "string",
      "description": "Coordination-repo branch holding the in-flight contract (when proposed)."
    },
    "contract_version": {
      "type": "string",
      "description": "EXACT pinned coordination-repo commit SHA the consumer builds against.",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "breaking": {
      "type": "boolean",
      "description": "Set by oasdiff, confirmed by a human."
    },
    "severity": { "type": "string", "enum": ["low", "medium", "high"] },
    "intent": { "type": "string", "minLength": 1 },
    "affects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target", "change"],
        "properties": {
          "target": { "type": "string", "description": "e.g. 'GET /orders'" },
          "change": { "type": "string" }
        }
      }
    },
    "required_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "migration": {
      "type": "array",
      "items": { "type": "string" }
    },
    "deadline": {
      "type": "string",
      "description": "ISO date (YYYY-MM-DD).",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "links": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "allOf": [
    {
      "$comment": "A breaking change must declare a migration path.",
      "if": { "properties": { "breaking": { "const": true } } },
      "then": { "required": ["migration"] }
    },
    {
      "$comment": "A proposed contract must name the branch it lives on.",
      "if": { "properties": { "contract_status": { "const": "proposed" } } },
      "then": { "required": ["contract_branch"] }
    },
    {
      "$comment": "from and to must differ.",
      "not": {
        "properties": {
          "from": { "const": "frontend" },
          "to": { "const": "frontend" }
        }
      }
    },
    {
      "not": {
        "properties": {
          "from": { "const": "backend" },
          "to": { "const": "backend" }
        }
      }
    }
  ]
}
